{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ShadowScoringRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "records"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "Caller-generated request identifier for shadow tracing."
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "transaction_id",
          "features"
        ],
        "properties": {
          "transaction_id": {
            "type": "string",
            "description": "Canonical transaction identifier for traceability."
          },
          "is_fraud": {
            "type": [
              "integer",
              "null"
            ],
            "enum": [
              0,
              1,
              null
            ],
            "description": "Optional ground-truth label used only for offline shadow evaluation."
          },
          "features": {
            "type": "object",
            "description": "Feature-name to numeric-value map aligned to the packaged feature contract.",
            "additionalProperties": {
              "type": [
                "number",
                "integer",
                "null"
              ]
            }
          },
          "metadata": {
            "type": "object",
            "description": "Opaque caller metadata echoed back in the response.",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "examples": [
    {
      "request_id": "shadow-2026-04-05-0001",
      "records": [
        {
          "transaction_id": "3663549",
          "is_fraud": null,
          "features": {
            "amount": 261.95,
            "c1": 5.0
          },
          "metadata": {
            "source": "go-shadow-client",
            "trace_id": "abc-123"
          }
        }
      ]
    }
  ]
}
