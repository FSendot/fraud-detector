[Unit]
Description=Fraud dashboard API (Python stdlib, detrás de nginx)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/fraud-api
# Solo localhost: nginx hace proxy desde el puerto 80
Environment=PORT=5000
Environment=HOST=127.0.0.1
ExecStart=/usr/bin/python3 /opt/fraud-api/app.py
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
